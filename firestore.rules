rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────
// IMPORTANT: The Flutter app authenticates against the custom Express
// server (not Firebase Auth), so these rules CANNOT check request.auth
// (there is none). Since almost all reads happen via direct Firestore
// listeners from the client with no Firebase Auth session, these rules
// can only meaningfully gate WRITES from stray/malicious clients — they
// cannot verify "this reader is really director X of school Y" the way
// Firebase Auth-based rules normally would.
//
// Practical recommendation: keep this app's Firestore in "test mode"
// equivalent (open read, restricted write to server-only) UNLESS you
// migrate the client to authenticate via Firebase Auth (custom tokens
// minted by this same Express server) — which would let these rules
// enforce real per-school / per-role isolation.
//
// Below is a pragmatic default: reads open (matches the current app's
// behavior of loading broad listeners), all writes blocked from the
// client (since every write already goes through the Express server,
// which uses the Admin SDK and bypasses these rules entirely).
// ─────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read: if true;
      allow write: if false; // all writes go through the Express server (Admin SDK)
    }
  }
}
