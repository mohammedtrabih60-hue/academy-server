PORT=3000
NODE_ENV=development

# Firebase - paste full service-account JSON as ONE line
FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_min_64_chars
JWT_EXPIRES_IN=30d

# First admin account (created automatically on first boot if it doesn't exist)
ADMIN_EMAIL=admin@academy.com
ADMIN_PASSWORD=ChangeMe@2024!
